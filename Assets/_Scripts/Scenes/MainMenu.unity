--- !u!114 &181709329
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 181709327}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>AMA\xC7</b>\n10 dakikal\u0131k haz\u0131rl\u0131kta en g\xFC\xE7l\xFC
    robot tak\u0131m\u0131n\u0131 kur \u2014 s\xFCre bitince robotlar arenada otomatik
    sava\u015F\u0131r!\n\n<b>KONTROLLER</b>\nWASD \u2014 Hareket      E \u2014 Al
    / Kullan      Q \u2014 Silah Geli\u015Ftir\nTab / F \u2014 Z\u0131rh Se\xE7imi\n\n<b>\xDCRET\u0130M
    Z\u0130NC\u0130R\u0130</b>\n1)  Tedarik kutusundan ham madde al (Demir, Devre,
    Ham Plazma)\n2)  \u0130\u015Fleme Masas\u0131'nda i\u015Fle \u2192 \xC7elik Plaka,
    Mikro\xE7ip, Plazma \xC7ekirde\u011Fi\n3)  \u015Easiye tak \u2192 HP / SPD /
    ATK kazan\u0131r\n4)  Ortadaki hurdal\u0131ktan madde topla \u2192 Silah At\xF6lyesi'nde
    silaha \xE7evir\n5)  \u0130ki FARKLI i\u015Flenmi\u015F \xFCr\xFCn\xFC Montaj
    \u0130stasyonu'nda birle\u015Ftir \u2192 Mod\xFCl\n6)  \u0130\u015Flenmi\u015F
    \xFCr\xFCnleri tak\u0131l\u0131 silaha ta\u015F\u0131 (Q) \u2192 seviye atlat
    (Lv5'e kadar)\n\n<b>\u0130PU\xC7LARI</b>\n\u2022  Kutunun rengi = verdi\u011Fi
    maddenin rengi. Renkleri ezberle!\n\u2022  Z\u0131rh se\xE7imi ta\u015F-ka\u011F\u0131t-makas:
    A\u011F\u0131r Plaka melee'yi keser ama rokete zay\u0131f.\n\u2022  Orta b\xF6lge
    rekabet\xE7i \u2014 rakip AI da oradan besleniyor say\u0131l\u0131r, h\u0131zl\u0131
    ol.\n\u2022  3 \u015Fasi doldurabilirsin: 3'e 3 tak\u0131m sava\u015F\u0131!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
